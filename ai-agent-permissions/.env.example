# API Key for OpenAI-compatible chat endpoint (required for IC-only and IC+CF methods)
OPENAI_API_KEY=your-api-key-here

# Optional custom base URL for OpenAI-compatible providers (e.g., DeepSeek)
# Leave empty for OpenAI default endpoint
# Example: OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_BASE_URL=

# Model name (optional, defaults to o4-mini)
# OpenAI examples: o4-mini, o3-mini-2025-01-31
# DeepSeek examples: deepseek-chat, deepseek-reasoner
OPENAI_MODEL=o4-mini
